{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "jsx": "preserve"
  },
  "include": [
    "zugz-plugin/**/*"
  ],
  "exclude": [
    "node_modules",
    "zugz-plugin/plugins/plugin_tui.tsx"
  ]
}
