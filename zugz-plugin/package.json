  "author": "Danielisla96",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.3.0",
    "@opencode-ai/plugin": "1.15.4",
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^9.3.0",
    "eslint-plugin-html": "^8.1.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
