{
  "name": "zugzbot-sdd",
  "version": "2.0.2",
  "description": "Zugzbot v2.0.0 - Stack-Agnostic SDD Harness with TDD Discipline for OpenCode",
  "main": "index.js",
  "type": "module",
  "bin": {
    "zugzbot": "./bin/zugzbot.js"
  },
  "scripts": {
    "lint": "eslint . --ext .js,.ts,.tsx,.jsx,.html",
    "lint:fix": "eslint . --ext .js,.ts,.tsx,.jsx,.html --fix",
    "test": "vitest run",
    "test:static": "node tools/sdd_ui_auditor.ts src",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "sdd",
    "spec-driven-development",
