        echo -e "    ${COLOR_SUCCESS}help${NC}             - Muestra esta tarjeta informativa de comandos"
        echo ""
        ;;
    *)
        echo -e "${COLOR_ERROR}Comando no reconocido: '$1'${NC}"
        echo -e "Usa './sdd help' para ver la lista de comandos disponibles."
        exit 1
        ;;
esac
