# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# OMD runtime data (regenerated by `npx oh-my-design-cli install-skills --all --force`)
.opencode/data/cache/
.opencode/data/.tmp/
.opencode/agents/.tmp/
# Regenerable OMD catalog (install on-demand via omd-bootstrap plugin)
.opencode/data/references/
.opencode/data/reference-fingerprints.json
.opencode/data/vocabulary.json
.opencode/data/synonyms.json
.opencode/data/reference-tags.md
.opencode/data/opt-out-corpus.json
.cursor/
.omd/cache/
.omd/runs/
.omd/
.opencode/oh-my-design/*
!.opencode/oh-my-design/design-md/
!.opencode/oh-my-design/design-md/**
!.opencode/oh-my-design/packages/
!.opencode/oh-my-design/packages/mcp/
!.opencode/oh-my-design/packages/mcp/package.json
!.opencode/oh-my-design/packages/mcp/dist/
!.opencode/oh-my-design/packages/mcp/dist/**

.playwright-mcp/
export_ses_*
package-lock.json
.openspec/.*