{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "jsx": "preserve"
  },
  "include": ["tools/**/*", "sdd-sidebar.ts", "sdd-plugin/**/*", "cost-monitor/**/*"]
}
