{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "./.openspec/prompt_base.md"
  ],
  "permission": {
    "task": {
      "sdd-*": "allow",
      "aux-*": "allow"
    }
  },
  "lsp": {
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts",
        ".gs"
      ]
    }
  },
  "formatter": {
    "prettier-openspec": {
      "command": ["npx", "prettier", "--write", "$FILE"],
      "extensions": [".md", ".json"]
    }
  },
  "agent": {
    "sdd-explorer": {
      "permission": {
        "bash": {
          "*": "ask",
          "ls": "allow",
          "ls *": "allow",
          "ls -la *": "allow",
          "find *": "allow",
          "cat *": "allow",
          "grep *": "allow",
          "wc *": "allow",
          "mkdir *": "allow",
          "mkdir -p *": "allow",
          "cp *": "allow",
          "mv *": "allow",
          "node --version": "allow",
          "node -v": "allow",
          "npm --version": "allow",
          "npm -v": "allow",
          "git log *": "allow",
          "git status": "allow",
          "git status *": "allow",
          "git branch": "allow",
          "git branch *": "allow",
          "npx autoskills": "allow",
          "npx autoskills *": "allow",
          "npx -y autoskills *": "allow",
          "sort *": "allow",
          "rg *": "allow",
          "awk *": "allow",
          "read *": "allow",
          "echo *": "allow",
          "head *": "allow",
          "uniq *": "allow"
        }
      }
    },
    "sdd-planner": {
      "permission": {
        "bash": {
          "*": "ask",
          "ls": "allow",
          "ls *": "allow",
          "mkdir *": "allow",
          "mkdir -p *": "allow",
          "wc *": "allow",
          "sort *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "awk *": "allow",
          "read *": "allow",
          "echo *": "allow",
          "head *": "allow",
          "uniq *": "allow",
          "git status": "allow",
          "git status *": "allow"
        }
      }
    },
    "sdd-builder": {
      "permission": {
        "bash": {
          "*": "ask",
          "ls": "allow",
          "ls *": "allow",
          "mkdir *": "allow",
          "mkdir -p *": "allow",
          "wc *": "allow",
          "sort *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "awk *": "allow",
          "read *": "allow",
          "echo *": "allow",
          "head *": "allow",
          "uniq *": "allow",
          "git status": "allow",
          "git status *": "allow",
          "npm test": "allow",
          "npm test *": "allow",
          "npm run test": "allow",
          "npm run test *": "allow",
          "npm run lint": "allow",
          "npm run lint *": "allow",
          "npx vitest *": "allow",
          "npx jest *": "allow"
        }
      }
    },
    "sdd-archiver": {
      "permission": {
        "bash": {
          "*": "ask",
          "ls": "allow",
          "ls *": "allow",
          "mkdir *": "allow",
          "mkdir -p *": "allow",
          "wc *": "allow",
          "sort *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "awk *": "allow",
          "read *": "allow",
          "echo *": "allow",
          "head *": "allow",
          "uniq *": "allow",
          "git status": "allow",
          "git status *": "allow",
          "git add *": "allow",
          "git commit *": "allow",
          "git checkout *": "allow",
          "git show-ref *": "allow"
        }
      }
    }
  }
}
