{
  "$schema": "https://opencode.ai/config.json",
  "theme": "tokyonight",
  "permission": {
    "*": "allow",
    "skill": {
      "omd-*": "allow",
      "stack-validator": "allow",
      "sdd-methodology": "allow",
      "sdd-quickstart": "allow",
      "sdd-tester-quickstart": "allow",
      "shadcn": "allow",
      "shadcn-templates": "allow",
      "docker-templates": "allow",
      "claude-design": "ask",
      "find-docs": "ask",
      "heroui-*": "deny",
      "hero-*": "deny",
      "*": "ask"
    }
  },
  "lsp": true,
  "instructions": [
    "./.openspec/DESIGN.md",
    "./.opencode/rules/sdd-global.md"
  ],
  "plugin": [
    "opencode-dynamic-context-pruning",
    "opencode-notificator"
  ],
  "mcp": {
    "oh-my-design": {
      "type": "local",
      "command": [
        "node",
        "./.opencode/oh-my-design/packages/mcp/dist/index.js"
      ],
      "enabled": true,
      "purpose": "MCP oficial de Oh My Design para buscar, consultar y aplicar temas de diseño (Toss, Stripe, Supabase, etc.)."
    },
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true,
      "purpose": "Librer\u00eda UI objetivo. Usar para browse/search/install de componentes y blocks (dashboards, landings, auth, forms)."
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--output-dir",
        ".openspec/.playwright",
        "--isolated"
      ],
      "enabled": true,
      "purpose": "Playwright MCP. Artefactos (screenshots, traces, videos, downloads) van a .openspec/.playwright/<call-id>/. Para evidencia por sesi\u00f3n SDD, promueve los artefactos relevantes a .openspec/specs/<activeContract>/playwright/ con .opencode/tools/save-playwright-artifacts.sh. --isolated evita ensuciar el perfil del browser en disco."
    },
    "next-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "next-devtools-mcp@latest"
      ],
      "enabled": false,
      "environment": {
        "NEXT_TELEMETRY_DISABLED": "1"
      },
      "purpose": "Toolchain oficial Vercel para Next.js 16. Provee init, nextjs_docs, nextjs_index/nextjs_call (errores, logs, rutas, Server Actions en runtime), browser_eval, upgrade_nextjs_16 y enable_cache_components. Complementa context7 (docs genérico) con docs y runtime específicos de Next 16 (dev server expone /_next/mcp). Telemetría desactivada explícitamente. **DESHABILITADO por defecto** — solo activar on-demand cuando un subagente reporte un error específico de Next 16 que requiera docs oficiales. La razón: el tool `init` inyecta 1000+ palabras de 'FORGET ALL PRIOR KNOWLEDGE' en el contexto del coder (~8K tokens de reasoning desperdiciado en sesiones normales)."
    },
    "lucide-icons": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "lucide-icons-mcp",
        "--stdio"
      ],
      "enabled": true,
      "purpose": "Permite buscar, filtrar y obtener ejemplos de uso JSX de m\u00e1s de 1,500 iconos de Lucide React de forma exacta mediante herramientas del MCP."
    }
  },
  "agent": {
    "sdd-orchestrator": {
      "description": "Coordinador principal del flujo SDD y del stack cerrado",
      "mode": "primary",
      "model": "deepseek/deepseek-v4-flash",
      "prompt": "{file:./.opencode/agents/sdd-orchestrator.md}",
      "permission": {
        "*": "allow",
        "write": "deny",
        "edit": "deny",
        "bash": "deny",
        "task": {
          "*": "deny",
          "sdd-*": "allow"
        }
      }
    },
    "sdd-spec-writer": {
      "description": "Redacta y valida contratos OpenAPI e interfaces en specs/",
      "mode": "subagent",
      "hidden": true,
      "model": "deepseek/deepseek-v4-flash",
      "prompt": "{file:./.opencode/agents/sdd-spec-writer.md}",
      "permission": {
        "*": "allow",
        "bash": "deny"
      }
    },
    "sdd-coder": {
      "description": "Implementa código ajustándose estrictamente a los contratos en specs/",
      "mode": "subagent",
      "hidden": true,
      "steps": 10,
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.35,
      "frequency_penalty": 0.5,
      "presence_penalty": 0.2,
      "prompt": "{file:./.opencode/agents/sdd-coder.md}\n\nContexto Activo de la Iteración:\n{file:./.opencode/active-brief.md}",
      "permission": {
        "*": "allow",
        "bash": {
          "*": "ask",
          "npm *": "allow",
          "pnpm *": "allow",
          "yarn *": "allow",
          "vitest *": "allow",
          "npx eslint *": "allow",
          "eslint *": "allow",
          "pytest *": "allow",
          "python3 *": "allow",
          "python *": "allow",
          "uv *": "allow",
          "pip *": "allow",
          "npx *": "allow",
          "npx shadcn*": "allow",
          "cat *": "allow"
        }
      }
    },
    "sdd-tester": {
      "description": "Diseña y corre pruebas unitarias, integración y visuales (Playwright)",
      "mode": "subagent",
      "hidden": true,
      "steps": 15,
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.35,
      "frequency_penalty": 0.5,
      "presence_penalty": 0.2,
      "prompt": "{file:./.opencode/agents/sdd-tester.md}\n\nContexto Activo de la Iteración:\n{file:./.opencode/active-brief.md}",
      "permission": {
        "*": "allow",
        "bash": {
          "*": "ask",
          "npm *": "allow",
          "pnpm *": "allow",
          "yarn *": "allow",
          "vitest *": "allow",
          "npx eslint *": "allow",
          "eslint *": "allow",
          "pytest *": "allow",
          "python3 *": "allow",
          "python *": "allow",
          "uv *": "allow",
          "pip *": "allow",
          "npx *": "allow",
          "npx shadcn*": "allow",
          "cat *": "allow"
        }
      }
    },
    "sdd-deployer": {
      "description": "Limpia Docker y realiza el despliegue local del sistema",
      "mode": "subagent",
      "hidden": true,
      "model": "deepseek/deepseek-v4-flash",
      "prompt": "{file:./.opencode/agents/sdd-deployer.md}",
      "permission": {
        "*": "allow"
      }
    }
  }
}