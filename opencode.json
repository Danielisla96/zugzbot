{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "sdd-spec-writer": {
      "mode": "subagent",
      "permission": {
        "webfetch": "deny"
      },
      "model": "deepseek/deepseek-v4-flash"
    }
  },
  "permission": {
    "*": "allow",
    "skill": {
      "omd-*": "allow",
      "stack-validator": "allow",
      "sdd-foundation-overview": "allow",
      "sdd-methodology": "allow",
      "sdd-quickstart": "allow",
      "sdd-tester-quickstart": "allow",
      "shadcn": "allow",
      "shadcn-templates": "allow",
      "docker-templates": "allow",
      "claude-design": "ask",
      "find-docs": "ask",
      "heroui-*": "deny",
      "hero-*": "deny",
      "*": "ask"
    }
  },
  "lsp": true,
  "instructions": [
    ".opencode/rules/sdd-global.md"
  ],
  "plugin": [
    "opencode-dynamic-context-pruning",
    "opencode-notificator"
  ],
  "mcp": {
    "oh-my-design": {
      "type": "local",
      "command": [
        "node",
        "./.opencode/oh-my-design/packages/mcp/dist/index.mjs"
      ],
      "enabled": true,
      "purpose": "Busca, consulta y aplica temas de diseño (Toss, Stripe, Supabase, etc.)."
    },
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true,
      "purpose": "Usa para browse/search/install de componentes y blocks oficiales de Shadcn UI."
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--output-dir",
        ".openspec/.playwright",
        "--isolated"
      ],
      "enabled": true,
      "purpose": "Ejecuta pruebas de regresión visual y capturas de pantalla de Playwright."
    },
    "next-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "next-devtools-mcp@latest"
      ],
      "enabled": false,
      "environment": {
        "NEXT_TELEMETRY_DISABLED": "1"
      },
      "purpose": "Toolchain oficial para depurar Next.js 16 (deshabilitado por defecto)."
    },
    "lucide-icons": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "lucide-icons-mcp",
        "--stdio"
      ],
      "enabled": true,
      "purpose": "Busca y obtiene ejemplos de uso de iconos de Lucide React."
    }
  }
}