{
  "$schema": "../../../.opencode/contract-schema.json",
  "contractName": "NoteColorsCategories",
  "description": "Añade sistema de colores a las notas (NoteColor type) con ColorPicker, indicadores visuales en NoteCard, filtro por color en NotesList y persistencia en localStorage",
  "category": "frontend",
  "settings": {
    "verificationMode": "console",
    "language": "TypeScript",
    "testFramework": "Vitest",
    "darkMode": "class-based (tailwind dark:)",
    "persistence": "localStorage"
  },
  "design": {
    "brand": "linear.app",
    "reference": ".openspec/design-assets/linear.app/DESIGN.md",
    "previews": ".openspec/design-assets/linear.app/preview.html",
    "tokens": {
      "primary": "#5e6ad2",
      "accent": "#7170ff",
      "accent-hover": "#828fff",
      "background": "#0f1011",
      "canvas": "#08090a",
      "surface": "#191a1b",
      "surface-2": "#28282c",
      "foreground": "#f7f8f8",
      "text-secondary": "#d0d6e0",
      "muted": "#8a8f98",
      "text-quaternary": "#62666d",
      "typography": {
        "family": "{ sans: \"Inter\", mono: \"Berkeley Mono\" }",
        "body": "{ size: 17, weight: 400, lineHeight: 1.60 }",
        "caption": "{ size: 14, weight: 510, lineHeight: 1.50, tracking: -0.182 }"
      },
      "rounded": "{ sm: 4, md: 8, lg: 12, full: 9999 }",
      "shadow": {
        "subtle": "rgba(0,0,0,0.03) 0px 1.2px 0px",
        "card": "rgba(0,0,0,0.08) 0px 0px 0px 1px, rgba(0,0,0,0.04) 0px 2px 4px 0px"
      },
      "card": {
        "bg": "rgba(255,255,255,0.02)",
        "border": "1px solid rgba(255,255,255,0.08)",
        "radius": "8px",
        "hover": "subtle background-opacity increase"
      },
      "filter-pill": {
        "bg": "transparent",
        "fg": "#d0d6e0",
        "border": "1px solid #23252a",
        "radius": "9999px",
        "height": "26px",
        "padding": "0 10px 0 5px",
        "font": "12px / 510"
      },
      "brand-fill-button": {
        "bg": "#5e6ad2",
        "fg": "#ffffff",
        "radius": "6px",
        "height": "32px",
        "padding": "0 16px",
        "font": "14px / 510",
        "hover": "#828fff"
      }
    }
  },
  "stack": {
    "core": ["Next.js 16", "Shadcn UI", "Tailwind CSS v4", "localStorage"],
    "databases": []
  },
  "routes": [
    {
      "path": "/",
      "name": "Home",
      "description": "Página principal con el listado de notas, filtros y editor",
      "layout": "AppLayout (Header + main content)",
      "components": ["AppLayout", "NotesList", "NoteCard", "NoteEditor", "ColorPicker", "SortControls"],
      "access": "public"
    }
  ],
  "frontend": {
    "components": [
      {
        "name": "ColorPicker",
        "path": "@/components/blocks/ColorPicker",
        "description": "Selector de 7 círculos de color (indigo, orange, green, red, purple, gray, none). Diseño Linear: círculos de 24px con border translúcido; el seleccionado tiene ring primary (indigo). El valor 'none' se representa como círculo con línea diagonal (Slash icon).",
        "props": {
          "value": "NoteColor",
          "onChange": "(color: NoteColor) => void"
        },
        "state": {
          "activeColor": "NoteColor (derived de value prop)"
        },
        "events": [
          "onChange(color) — cuando el usuario clickea un círculo de color"
        ]
      },
      {
        "name": "NoteEditor",
        "path": "@/components/blocks/NoteEditor",
        "description": "MODIFICADO: Añadir color state y ColorPicker entre el título y el textarea. El color se inicializa desde note.color si se edita una nota existente. Se pasa en onSave.",
        "props": {
          "note": "Note | null",
          "isOpen": "boolean",
          "onClose": "() => void",
          "onSave": "(noteData: { id?: string; title: string; content: string; color?: NoteColor }) => void"
        },
        "state": {
          "title": "string",
          "content": "string",
          "color": "NoteColor (default: 'none')",
          "showTemplateSelector": "boolean",
          "showPreview": "boolean"
        },
        "events": [
          "onSave({ id, title, content, color }) — al guardar incluye color"
        ]
      },
      {
        "name": "NoteCard",
        "path": "@/components/blocks/NoteCard",
        "description": "MODIFICADO: Si note.color no es 'none', muestra dot de color en border-left, badge con nombre del color, y tinte sutil de fondo (lightBg).",
        "props": {
          "note": "Note (ahora incluye color opcional)",
          "onEdit": "(note: Note) => void",
          "onDelete": "(id: string) => void",
          "onToggleFavorite": "(id: string) => void",
          "onTogglePin": "(id: string) => void",
          "style": "React.CSSProperties"
        },
        "state": {
          "showMarkdown": "boolean"
        }
      },
      {
        "name": "NotesList",
        "path": "@/components/blocks/NotesList",
        "description": "MODIFICADO: Añadir filtro de color tipo pill buttons (horizontal row). 'Todas' + círculos de colores. Estado activo con indigo ring/border estilo Linear.",
        "props": {
          "notes": "Note[]",
          "onEdit": "(note: Note) => void",
          "onDelete": "(id: string) => void",
          "onToggleFavorite": "(id: string) => void",
          "onTogglePin": "(id: string) => void",
          "onCreateNew": "() => void",
          "sortBy": "SortBy",
          "onSortChange": "(sort: SortBy) => void",
          "onFilteredCountChange": "(count: number) => void"
        },
        "state": {
          "searchQuery": "string",
          "colorFilter": "NoteColor | null"
        },
        "events": [
          "onColorFilterChange(color) — actualiza filtro por color"
        ]
      }
    ],
    "types": {
      "path": "@/types/index",
      "additions": {
        "NoteColor": "\"indigo\" | \"orange\" | \"green\" | \"red\" | \"purple\" | \"gray\" | \"none\"",
        "Note.color": "NoteColor (opcional, default: 'none')"
      }
    },
    "lib": {
      "colors": {
        "path": "@/lib/colors",
        "description": "Mapa de definiciones de colores NOTE_COLORS: Record<NoteColor, { label, dot, lightBg, hex }>"
      }
    }
  },
  "stateFlow": {
    "owner": "NotesList",
    "lifts_to": null,
    "props_down": [
      { "from": "NotesList", "to": "NoteCard", "prop": "note", "type": "data" },
      { "from": "NotesList", "to": "NoteCard", "prop": "onEdit", "type": "callback" },
      { "from": "NotesList", "to": "NoteCard", "prop": "onDelete", "type": "callback" },
      { "from": "NotesList", "to": "NoteCard", "prop": "onToggleFavorite", "type": "callback" },
      { "from": "NotesList", "to": "NoteCard", "prop": "onTogglePin", "type": "callback" },
      { "from": "HomePage", "to": "NotesList", "prop": "notes", "type": "data" },
      { "from": "HomePage", "to": "NoteEditor", "prop": "note", "type": "data" },
      { "from": "HomePage", "to": "NoteEditor", "prop": "isOpen", "type": "data" },
      { "from": "HomePage", "to": "NoteEditor", "prop": "onSave", "type": "callback" }
    ],
    "forbidden": [
      "instanciar colorFilter state en HomePage (debe vivir en NotesList)",
      "instanciar useState en componentes hijos de NotesList para datos que vienen por props",
      "usar context global sin provider"
    ]
  },
  "test_scenarios": [
    {
      "id": "CLR-01",
      "name": "ColorPicker renderiza los 7 colores",
      "type": "unit",
      "feature_ref": "ColorPicker",
      "given": "el ColorPicker se monta con value='none'",
      "when": "se renderiza el componente",
      "then": "se muestran 7 botones/círculos de color incluyendo el círculo con Slash (none)"
    },
    {
      "id": "CLR-02",
      "name": "ColorPicker selecciona un color y llama onChange",
      "type": "unit",
      "feature_ref": "ColorPicker",
      "given": "el ColorPicker está renderizado con value='none'",
      "when": "el usuario hace click en el círculo de color 'indigo'",
      "then": "onChange se llama con 'indigo'"
    },
    {
      "id": "CLR-03",
      "name": "NoteEditor guarda nota con color seleccionado",
      "type": "unit",
      "feature_ref": "NoteEditor",
      "given": "el NoteEditor está abierto en modo creación",
      "when": "el usuario selecciona color 'green', escribe título y contenido, y hace click en Guardar",
      "then": "onSave se llama con un objeto que incluye title, content y color='green'"
    },
    {
      "id": "CLR-04",
      "name": "NoteCard muestra indicador visual de color",
      "type": "unit",
      "feature_ref": "NoteCard",
      "given": "una nota con color='purple'",
      "when": "se renderiza NoteCard",
      "then": "la card tiene border-l-[3px] con el color purple y muestra un badge con label 'Purple'"
    },
    {
      "id": "CLR-05",
      "name": "NotesList filtra correctamente por color",
      "type": "unit",
      "feature_ref": "NotesList",
      "given": "NotesList tiene notas de varios colores (indigo, green, none)",
      "when": "el usuario hace click en el filtro de color 'green'",
      "then": "solo se muestran las notas con color='green'"
    },
    {
      "id": "CLR-06",
      "name": "NoteEditor inicializa color desde nota existente",
      "type": "unit",
      "feature_ref": "NoteEditor",
      "given": "el NoteEditor se abre con una nota existente que tiene color='orange'",
      "when": "se renderiza el editor",
      "then": "el ColorPicker muestra 'orange' como valor seleccionado"
    }
  ],
